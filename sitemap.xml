---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% for page in site.pages %}
    {% unless page.url contains ".xml" or page.url contains ".css" or page.url contains ".js" %}
  <url>
    <loc>{{ page.url | absolute_url }}</loc>
  </url>
    {% endunless %}
  {% endfor %}

  {% for wine in site.wines %}
  <url>
    <loc>{{ wine.url | absolute_url }}</loc>
  </url>
  {% endfor %}

  {% for brand in site.brands %}
  <url>
    <loc>{{ brand.url | absolute_url }}</loc>
  </url>
  {% endfor %}
</urlset>